{
  "name": "paper-translate-for-zotero",
  "version": "1.1.0",
  "description": "Context-aware academic translation from validated llm-for-zotero MinerU Markdown.",
  "config": {
    "addonName": "Paper Translate for Zotero",
    "addonID": "papertranslateforzotero@woif-sha.github.io",
    "addonRef": "papertranslateforzotero",
    "prefsPrefix": "extensions.zotero.PaperTranslateForZotero",
    "addonInstance": "PaperTranslate"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "tsc --noEmit && zotero-plugin build",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"typings/**/*.ts\" \".github/**/*.yml\" addon/chrome/content/preferences.xhtml addon/manifest.json \"addon/*.js\" README.md CHANGELOG.md AGENTS.md package.json zotero-plugin.config.ts eslint.config.mjs",
    "release": "zotero-plugin release",
    "lint": "prettier --write . && eslint . --fix",
    "test": "node --test --test-concurrency=1 --test-timeout=60000 --import tsx test/**/*.test.ts",
    "update-deps": "npm update --save"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Woif-sha/paper-translate-for-zotero.git"
  },
  "author": "Woif-sha and contributors",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Woif-sha/paper-translate-for-zotero/issues"
  },
  "homepage": "https://github.com/Woif-sha/paper-translate-for-zotero#readme",
  "dependencies": {
    "franc": "^6.2.0",
    "iso639-js": "^1.1.3",
    "zotero-plugin-toolkit": "^5.1.0-beta.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.16.5",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.3"
  }
}
